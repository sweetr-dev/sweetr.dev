{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sweetr Docs",
  "logo": {
    "dark": "/logo.svg",
    "light": "/logo.svg"
  },
  "icons": {
    "library": "tabler"
  },
  "favicon": "/logo.svg",
  "colors": {
    "primary": "#69db7c"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#141517"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Login",
        "href": "https://app.sweetr.dev/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://github.com/apps/sweetr-dev/installations/new"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Repository",
          "icon": "github",
          "href": "https://github.com/sweetr-dev/sweetr.dev"
        },
        {
          "anchor": "Changelog",
          "icon": "list",
          "href": "/changelog"
        },
        {
          "anchor": "Give Feedback",
          "icon": "message-code",
          "href": "https://sweetr.featurebase.app/"
        }
      ]
    },

    "tabs": [
      {
        "tab": "Changelog",
        "pages": [
          {
            "group": "",
            "pages": ["changelog"]
          }
        ]
      },
      {
        "tab": "Sweetr",
        "pages": [
          {
            "group": "Welcome",
            "pages": [
              "get-started/intro",
              {
                "group": "Get Started",
                "icon": "sparkles",
                "pages": [
                  "get-started/cloud",
                  "get-started/self-host",
                  "get-started/onboarding"
                ]
              }
            ]
          },
          {
            "group": "Metrics & Insights",
            "pages": [
              "metrics-and-insights/dora",
              {
                "group": "Pull Request Flow",
                "icon": "activity",
                "pages": [
                  "metrics-and-insights/pr-flow/intro",
                  "metrics-and-insights/pr-flow/throughput",
                  "metrics-and-insights/pr-flow/size-distribution",
                  "metrics-and-insights/pr-flow/cycle-time-breakdown",
                  "metrics-and-insights/pr-flow/size-vs-cycle-time",
                  "metrics-and-insights/pr-flow/team-overview"
                ]
              },
              {
                "group": "Code Review Efficiency",
                "icon": "eye",
                "pages": [
                  "metrics-and-insights/code-review-efficiency/intro",
                  "metrics-and-insights/code-review-efficiency/kpis",
                  "metrics-and-insights/code-review-efficiency/review-speed",
                  "metrics-and-insights/code-review-efficiency/team-overview",
                  "metrics-and-insights/code-review-efficiency/pr-size-vs-comments",
                  "metrics-and-insights/code-review-efficiency/review-distribution"
                ]
              },
              "metrics-and-insights/work-log",
              "metrics-and-insights/wip"
            ]
          },
          {
            "group": "Automations",
            "pages": [
              "automations/alerts",
              "automations/digests",
              "automations/incident-detection",
              "automations/pr-size-labeler",
              "automations/pr-title-check"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/teams",
              "platform/people",
              "platform/pull-requests",
              "platform/code-reviews",
              "platform/applications",
              "platform/deployments",
              "platform/incidents",
              "platform/environments",
              "platform/integrations"
            ]
          },
          {
            "group": "About Us",
            "pages": [
              "about/principles",
              "about/open-source",
              "about/data-privacy-and-security",
              "about/roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/rate-limit"
            ]
          },
          {
            "group": "Deployments",
            "pages": ["api-reference/deployments/create-deployment"]
          }
        ]
      }
    ],
    "groups": []
  },
  "api": {
    "mdx": {
      "server": "https://api.sweetr.dev",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sweetr_dev",
      "github": "https://github.com/sweetr-dev",
      "linkedin": "https://www.linkedin.com/company/sweetr-dev"
    }
  }
}
