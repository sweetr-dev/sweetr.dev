{
  "name": "sweetr.dev",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter api --filter web --filter @sweetr/graphql-types",
    "graphql:generate": "npm run generate --workspace @sweetr/graphql-types",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "ssl:generate": "node ./certs/devcert.js",
    "heroku-postbuild": "turbo run build --filter api",
    "start": "cd apps/api && npm run start",
    "test": "turbo run test:unit test:integration",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "_ngrok": "ngrok http https://api.sweetr.local:8000 --domain $NGROK_DOMAIN",
    "ngrok": "dotenv -e ./apps/api/.env -- npm run _ngrok"
  },
  "dependencies": {
    "rimraf": "^6.0.0"
  },
  "devDependencies": {
    "devcert": "^1.2.2",
    "dotenv-cli": "^7.4.2",
    "prettier": "latest",
    "turbo": "latest"
  },
  "overrides": {
    "ioredis": "5.9.3",
    "minimatch": ">=10.2.1",
    "tmp": "0.2.5",
    "tar": ">=7.5.8",
    "@isaacs/brace-expansion": ">=5.0.1",
    "qs": ">=6.15.0",
    "lodash": ">=4.17.23",
    "lodash-es": ">=4.17.23",
    "ajv": ">=6.14.0",
    "axios": ">=1.13.5",
    "jws": ">=3.2.3",
    "js-yaml": ">=4.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@8.5.5"
}
